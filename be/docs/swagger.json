{
  "openapi": "3.0.3",
  "info": {
    "title": "Mobile App Backend API",
    "description": "REST API for root info, health check, and user management.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://20.255.57.186:8080",
      "description": "Production server"
    },
    {
      "url": "http://localhost:8080",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "root",
      "description": "Root/home endpoint"
    },
    {
      "name": "health",
      "description": "Service health"
    },
    {
      "name": "users",
      "description": "User CRUD operations"
    },
    {
      "name": "comments",
      "description": "Comment operations (get, add, delete, like/unlike)"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": [
          "root"
        ],
        "summary": "Get API metadata",
        "operationId": "getRoot",
        "responses": {
          "200": {
            "description": "API metadata response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RootSuccessResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Health check",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/users": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "Get users with pagination",
        "operationId": "getAllUsers",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Users per page",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated users",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserListSuccessResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "users"
        ],
        "summary": "Create a user",
        "operationId": "createUser",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserCreateInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserSuccessResponse"
                }
              }
            }
          },
          "409": {
            "description": "Email already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/users/{id}": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "Get user by id",
        "operationId": "getUserById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of user",
            "schema": {
              "type": "string",
              "example": "661fb4e9680c5e2a86f9f7b1"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserSuccessResponse"
                }
              }
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Invalid id format or server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "users"
        ],
        "summary": "Update user by id",
        "operationId": "updateUser",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of user",
            "schema": {
              "type": "string",
              "example": "661fb4e9680c5e2a86f9f7b1"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserUpdateInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserSuccessResponse"
                }
              }
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "users"
        ],
        "summary": "Delete user by id",
        "operationId": "deleteUser",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of user",
            "schema": {
              "type": "string",
              "example": "661fb4e9680c5e2a86f9f7b1"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteSuccessResponse"
                }
              }
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/comment/{id}": {
      "get": {
        "tags": ["comments"],
        "summary": "Lấy danh sách comments theo postId (phân trang)",
        "operationId": "getComments",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID của entity (post, food, restaurant, v.v.)",
            "schema": {"type": "string", "example": "661fb4e9680c5e2a86f9f7b1"}
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {"type": "integer", "default": 1}
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {"type": "integer", "default": 10}
          }
        ],
        "responses": {
          "200": {
            "description": "Danh sách comments",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/CommentListResponse"}
              }
            }
          },
          "401": {"description": "Unauthorized - Token không hợp lệ hoặc hết hạn"},
          "400": {"description": "Bad Request - postId không hợp lệ"}
        }
      },
      "post": {
        "tags": ["comments"],
        "summary": "Thêm comment mới",
        "operationId": "addComment",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID của entity được comment",
            "schema": {"type": "string", "example": "661fb4e9680c5e2a86f9f7b1"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/CommentCreateInput"}
            }
          }
        },
        "responses": {
          "201": {
            "description": "Comment đã được tạo",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/CommentResponse"}
              }
            }
          },
          "400": {"description": "Bad Request - Thiếu content hoặc postId không hợp lệ"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Not Found - postId không tồn tại"}
        }
      }
    },
    "/api/comment/{id}/remove": {
      "delete": {
        "tags": ["comments"],
        "summary": "Xóa comment (chỉ chủ sở hữu)",
        "operationId": "removeComment",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "postId",
            "schema": {"type": "string", "example": "661fb4e9680c5e2a86f9f7b1"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/CommentDeleteInput"}
            }
          }
        },
        "responses": {
          "200": {"description": "Comment đã bị xóa"},
          "400": {"description": "Bad Request - Thiếu cmtId"},
          "401": {"description": "Unauthorized"},
          "403": {"description": "Forbidden - Không phải chủ sở hữu comment"},
          "404": {"description": "Not Found - Comment không tồn tại"}
        }
      }
    },
    "/api/comment/{id}/like": {
      "put": {
        "tags": ["comments"],
        "summary": "Like hoặc Unlike một comment",
        "operationId": "likeComment",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "postId",
            "schema": {"type": "string", "example": "661fb4e9680c5e2a86f9f7b1"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/CommentLikeInput"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cập nhật like thành công",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/CommentResponse"}
              }
            }
          },
          "400": {"description": "Bad Request - Thiếu cmtId hoặc type không hợp lệ"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Not Found - Comment không tồn tại"},
          "409": {"description": "Conflict - Đã like hoặc chưa like"}
        }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "661fb4e9680c5e2a86f9f7b1"
          },
          "name": {
            "type": "string",
            "example": "Nguyen Van A"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "vana@example.com"
          },
          "phone": {
            "type": "string",
            "nullable": true,
            "example": "0909123456"
          },
          "avatar": {
            "type": "string",
            "nullable": true,
            "example": "https://example.com/avatar.png"
          },
          "role": {
            "type": "string",
            "enum": [
              "user",
              "admin"
            ],
            "example": "user"
          },
          "isActive": {
            "type": "boolean",
            "example": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "name",
          "email",
          "role",
          "isActive",
          "createdAt",
          "updatedAt"
        ]
      },
      "UserCreateInput": {
        "type": "object",
        "required": [
          "name",
          "email"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 50,
            "example": "Nguyen Van A"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "vana@example.com"
          },
          "phone": {
            "type": "string",
            "example": "0909123456"
          },
          "avatar": {
            "type": "string",
            "example": "https://example.com/avatar.png"
          },
          "role": {
            "type": "string",
            "enum": [
              "user",
              "admin"
            ],
            "default": "user"
          },
          "isActive": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "UserUpdateInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 50,
            "example": "Nguyen Van B"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "vanb@example.com"
          },
          "phone": {
            "type": "string",
            "example": "0911222333"
          },
          "avatar": {
            "type": "string",
            "example": "https://example.com/new-avatar.png"
          },
          "role": {
            "type": "string",
            "enum": [
              "user",
              "admin"
            ]
          },
          "isActive": {
            "type": "boolean"
          }
        },
        "description": "All fields are optional for update."
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "example": 1
          },
          "limit": {
            "type": "integer",
            "example": 10
          },
          "total": {
            "type": "integer",
            "example": 42
          },
          "pages": {
            "type": "integer",
            "example": 5
          }
        },
        "required": [
          "page",
          "limit",
          "total",
          "pages"
        ]
      },
      "RootData": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Welcome to Mobile App Backend"
          },
          "version": {
            "type": "string",
            "example": "1.0.0"
          },
          "endpoints": {
            "type": "object",
            "properties": {
              "users": {
                "type": "string",
                "example": "/api/users"
              },
              "health": {
                "type": "string",
                "example": "/health"
              }
            },
            "required": [
              "users",
              "health"
            ]
          }
        },
        "required": [
          "message",
          "version",
          "endpoints"
        ]
      },
      "RootSuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "API is running"
          },
          "data": {
            "$ref": "#/components/schemas/RootData"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "success",
          "message",
          "data",
          "timestamp"
        ]
      },
      "UserSuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "User retrieved successfully"
          },
          "data": {
            "$ref": "#/components/schemas/User"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "success",
          "message",
          "data",
          "timestamp"
        ]
      },
      "UserListSuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Users retrieved successfully"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "success",
          "message",
          "data",
          "pagination",
          "timestamp"
        ]
      },
      "DeleteSuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "User deleted successfully"
          },
          "data": {
            "nullable": true,
            "example": null
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "success",
          "message",
          "timestamp"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string",
            "example": "Failed to fetch users"
          },
          "error": {
            "nullable": true,
            "example": "Cast to ObjectId failed for value \"abc\""
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "success",
          "message",
          "timestamp"
        ]
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "OK"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "status",
          "timestamp"
        ]
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "example": "6630abcd1234567890abcdef"},
          "postId": {"type": "string", "example": "661fb4e9680c5e2a86f9f7b1"},
          "userId": {
            "type": "object",
            "properties": {
              "_id": {"type": "string"},
              "username": {"type": "string"},
              "name": {"type": "string"},
              "avatar": {"type": "string", "nullable": true}
            }
          },
          "content": {"type": "string", "example": "Món ăn rất ngon!"},
          "likeCount": {"type": "integer", "example": 5},
          "likes": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Danh sách userId đã like"
          },
          "createdAt": {"type": "string", "format": "date-time"},
          "updatedAt": {"type": "string", "format": "date-time"}
        }
      },
      "CommentCreateInput": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000,
            "example": "Món ăn rất ngon, tôi rất thích!"
          }
        }
      },
      "CommentDeleteInput": {
        "type": "object",
        "required": ["cmtId"],
        "properties": {
          "cmtId": {
            "type": "string",
            "description": "ID của comment cần xóa",
            "example": "6630abcd1234567890abcdef"
          }
        }
      },
      "CommentLikeInput": {
        "type": "object",
        "required": ["cmtId", "type"],
        "properties": {
          "cmtId": {
            "type": "string",
            "description": "ID của comment",
            "example": "6630abcd1234567890abcdef"
          },
          "type": {
            "type": "string",
            "enum": ["inc", "dec"],
            "description": "'inc' để like, 'dec' để unlike",
            "example": "inc"
          }
        }
      },
      "CommentResponse": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean", "example": true},
          "message": {"type": "string", "example": "Comment added successfully"},
          "data": {"$ref": "#/components/schemas/Comment"},
          "timestamp": {"type": "string", "format": "date-time"}
        }
      },
      "CommentListResponse": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean", "example": true},
          "message": {"type": "string", "example": "Comments retrieved successfully"},
          "data": {
            "type": "array",
            "items": {"$ref": "#/components/schemas/Comment"}
          },
          "pagination": {"$ref": "#/components/schemas/Pagination"},
          "timestamp": {"type": "string", "format": "date-time"}
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Nhập access token nhận được sau khi login"
      }
    }
  }
}
